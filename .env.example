# Required for live Devin mode. Without these, the app runs in deterministic demo mode.
DEVIN_API_KEY=cog_your_service_user_key
DEVIN_ORG_ID=org-your-org-id

# Repository Devin should work in. For the assignment, point this at your Superset fork.
DEVIN_REPO=Ritwik-Gaur/superset
TARGET_REPOSITORY=Ritwik-Gaur/superset

# Optional: create GitHub issue comments and publish seeded issues.
GITHUB_TOKEN=ghp_your_token
GITHUB_WEBHOOK_SECRET=change-me

# Automation behavior.
TRIGGER_LABEL=devin-remediate
DEVIN_DRY_RUN=false
MAX_PARALLEL_SESSIONS=2
DEVIN_POLL_SECONDS=20
DEVIN_MAX_ACU_LIMIT=8

